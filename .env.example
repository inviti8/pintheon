# Pintheon Environment Configuration
# Copy to .env and edit for your environment.
# All values below show defaults — uncomment and change as needed.

# Network: testnet or mainnet
PINTHEON_NETWORK=testnet

# Data paths (defaults work for most setups)
# PINTHEON_DATA_DIR=~/.local/share/PINTHEON
# PINTHEON_DB_PATH=${PINTHEON_DATA_DIR}/db
# PINTHEON_IPFS_PATH=${PINTHEON_DATA_DIR}/ipfs

# IPFS daemon URL (Kubo RPC)
# PINTHEON_IPFS_DAEMON=http://127.0.0.1:5001

# Flask server
# PINTHEON_PORT=9999
# PINTHEON_HOST=0.0.0.0
